*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;

    background:linear-gradient(
        135deg,
        #0f3bff,
        #9333ea
    );
}

.card{
    width:700px;
    background:white;
    padding:50px;
    border-radius:25px;
    text-align:center;

    box-shadow:
    0 20px 40px rgba(0,0,0,.15);
}

.avatar{
    font-size:80px;
    margin-bottom:20px;
}

h1{
    color:#0f2d6b;
    margin-bottom:10px;
}

.subtitle{
    color:#666;
    margin-bottom:30px;
}

.btn{
    display:inline-block;

    padding:15px 40px;

    border-radius:30px;

    text-decoration:none;

    color:white;

    background:linear-gradient(
        90deg,
        #2563eb,
        #9333ea
    );

    font-weight:bold;
}

.goal{
    margin-top:30px;

    padding:20px;

    border:2px solid #7ee787;

    border-radius:12px;

    background:#f0fff4;

    color:#14532d;
}

.skills{
    display:flex;

    justify-content:space-around;

    margin-top:40px;
}

.skill{
    display:flex;
    flex-direction:column;
    gap:10px;
    font-size:30px;
}

.skill span{
    font-size:16px;
}

footer{
    margin-top:40px;
    color:#777;
}
